# ==> file types to be handled via git Large File Storage (LFS) https://git-lfs.com/
## generic .gitattributes for Python (from: https://github.com/gitattributes/gitattributes/blob/master/Python.gitattributes)
*.pxd           text diff=python
*.py            text diff=python
*.py3           text diff=python
*.pyw           text diff=python
*.pyx           text diff=python
*.pyz           text diff=python
*.pyi           text diff=python

### Binary files
*.pyc           binary export-ignore
*.pyo           binary export-ignore
*.pyd           binary

## these types are to be handled via LFS *anywhere*
*.pdf           filter=lfs diff=lfs merge=lfs -text
*.shp           filter=lfs diff=lfs merge=lfs -text
*.xml           filter=lfs diff=lfs merge=lfs -text
*.7z            filter=lfs diff=lfs merge=lfs -text
*.zip           filter=lfs diff=lfs merge=lfs -text
*.db            filter=lfs diff=lfs merge=lfs -text
*.p             filter=lfs diff=lfs merge=lfs -text
*.pkl           filter=lfs diff=lfs merge=lfs -text
*.pickle        filter=lfs diff=lfs merge=lfs -text
*.npy           filter=lfs diff=lfs merge=lfs -text
*.parquet       filter=lfs diff=lfs merge=lfs -text
*.ipynb         filter=lfs diff=lfs merge=lfs -text
*.log           filter=lfs diff=lfs merge=lfs -text
*.xlsx          filter=lfs diff=lfs merge=lfs -text
### add your own here...

## the "data" folder: since manual changes are discouraged, treat even readable files as LFS
data/*.csv      filter=lfs diff=lfs merge=lfs -text
data/*.tsv      filter=lfs diff=lfs merge=lfs -text
### add your own here...

## the "outputs" folder: same as data folder
outputs/*.csv   filter=lfs diff=lfs merge=lfs -text
outputs/*.tsv   filter=lfs diff=lfs merge=lfs -text
### add your own here...

## the "archive" folder: everything here gets treated as a large file
/archive/*      filter=lfs diff=lfs merge=lfs -text
